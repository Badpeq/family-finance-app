# Supabase — obtener en: https://supabase.com/dashboard/project/<tu-proyecto>/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://<tu-proyecto>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<tu-anon-key>

# Google Sheet con tipo de cambio PEN/USD del día.
# Publicar la hoja como CSV: Archivo → Publicar en la web → CSV → copiar URL.
# Si se omite, el servicio cae a open.er-api.com y luego al fallback 3.68/3.72.
EXPO_PUBLIC_GOOGLE_SHEET_URL=
