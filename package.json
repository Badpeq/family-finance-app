{
  "name": "family-finance-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-community/datetimepicker": "9.1.0",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.107.0",
    "expo": "~56.0.9",
    "expo-constants": "~56.0.17",
    "expo-file-system": "~56.0.8",
    "expo-image-picker": "~56.0.21",
    "expo-linking": "~56.0.13",
    "expo-local-authentication": "~56.0.4",
    "expo-notifications": "~56.0.16",
    "expo-router": "~56.2.9",
    "expo-secure-store": "~56.0.4",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "@vercel/node": "^5.8.17",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.5",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "test": "jest --testPathPattern='__tests__'",
    "test:watch": "jest --watch --testPathPattern='__tests__'",
    "test:coverage": "jest --coverage --testPathPattern='__tests__'"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/"
    ]
  },
  "private": true
}
